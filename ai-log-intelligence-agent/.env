# Path on YOUR HOST machine that contains logs.
# Docker mounts this host path into backend container at /data/logs (read-only).

# macOS/Linux example:
# LOG_FOLDER=/Users/name/logs

# Windows example (Docker Desktop + Compose):
# LOG_FOLDER=C:/logs
# If C:/logs fails in your shell, try:
# LOG_FOLDER=/c/logs
LOG_FOLDER=/Users/georgemelroy/PERSONAL/loglens/logs
